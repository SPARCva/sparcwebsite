# Access Trails NOVA — Contribute form configuration
#
# No build step: these values are pasted directly into
# accesstrails/js/supabaseClient.js. This file documents what they are.
# NEVER commit a real .env or the service-role key.
#
# Supabase dashboard -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# The anon/public key is safe in the browser; Row Level Security protects data.
# DO NOT put the service-role key anywhere client-side.
#
# Backend is LIVE (migrations applied); SUBMISSIONS_ENABLED is true in
# accesstrails/js/supabaseClient.js. The Team Console uses email+password auth
# (no magic links / no Resend), matching the /ART app.
