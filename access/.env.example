# Steps Toward Access — required configuration
#
# This is a no-build static site, so these values are pasted directly into
# access/js/supabaseClient.js. This file documents what they are and where to
# find them. NEVER commit a real .env or the service-role key.
#
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# DO NOT put the service-role key anywhere client-side.
# Only the anon/public key ships to the browser; Row Level Security protects the data.
